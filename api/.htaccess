Options -Indexes
RewriteEngine On

# ── Teruskan Authorization header ke PHP ──────────────────────────────────
# Beberapa hosting strip header ini sebelum sampai ke PHP
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteRule ^ - [E=REDIRECT_HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Fallback untuk PHP-CGI / FastCGI (shared hosting)
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# ── Static uploads langsung ───────────────────────────────────────────────
RewriteCond %{REQUEST_URI} ^/uploads/ [NC]
RewriteRule ^ - [L]

# ── OPTIONS preflight ─────────────────────────────────────────────────────
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ index.php [QSA,L]

# ── Route semua ke index.php ──────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# ── CORS ──────────────────────────────────────────────────────────────────
Header always set Access-Control-Allow-Origin "*"
Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Authorization, Content-Type, Accept, X-Requested-With"
Header always set Access-Control-Expose-Headers "Authorization"
